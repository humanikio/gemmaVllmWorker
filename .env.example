# ── Gemma 4 MoE Worker ──────────────────────────────────────────────
# Copy to .env for local development: cp .env.example .env

# Model
# Note: Do NOT set QUANTIZATION — vLLM auto-detects compressed-tensors format
MODEL_NAME=cyankiwi/gemma-4-26B-A4B-it-AWQ-4bit
DTYPE=float16

# Context & memory
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.95

# OpenAI compatibility
OPENAI_SERVED_MODEL_NAME_OVERRIDE=gemma-4-26b-moe
RAW_OPENAI_OUTPUT=1

# Performance
MAX_CONCURRENCY=30
ENABLE_PREFIX_CACHING=true
ENFORCE_EAGER=false

# Streaming batches
DEFAULT_BATCH_SIZE=50
DEFAULT_MIN_BATCH_SIZE=1
DEFAULT_BATCH_SIZE_GROWTH_FACTOR=3

# Logging (enable for debugging)
ENABLE_LOG_REQUESTS=false
DISABLE_LOG_STATS=false

# HuggingFace (only needed for gated/private models)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
