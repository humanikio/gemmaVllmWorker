# ── gemmaVllmWorker Environment Variables ───────────────────────────
# Copy to .env for local development: cp .env.example .env
#
# In production, these are injected by Humanik Cloud control plane
# when creating a pod. You do not set them manually.

# ═══════════════════════════════════════════════════════════════════
# MODEL (baked into Docker image — override only if needed)
# ═══════════════════════════════════════════════════════════════════
# MODEL_NAME=cyankiwi/gemma-4-26B-A4B-it-AWQ-4bit
# Do NOT set QUANTIZATION — compressed-tensors format, vLLM auto-detects

# ═══════════════════════════════════════════════════════════════════
# SERVER
# ═══════════════════════════════════════════════════════════════════
PORT=8000

# ═══════════════════════════════════════════════════════════════════
# VLLM ENGINE
# ═══════════════════════════════════════════════════════════════════
MAX_MODEL_LEN=8192
GPU_MEMORY_UTILIZATION=0.95
MAX_CONCURRENCY=30
ENABLE_PREFIX_CACHING=true
OPENAI_SERVED_MODEL_NAME_OVERRIDE=gemma-4-26b-moe

# ═══════════════════════════════════════════════════════════════════
# HUMANIK CLOUD — Instance Identity
# Injected by control plane at pod creation. Required for heartbeat,
# HMAC auth, and ALB routing. Without these, heartbeat is disabled
# and the server runs in standalone mode (useful for local dev).
# ═══════════════════════════════════════════════════════════════════
# NEXUS_TENANT_ID=tenant_abc123
# NEXUS_SERVICE_ID=svc_gemma
# NEXUS_INSTANCE_ID=inst_a1b2c3d4e5f6
# NEXUS_PROVIDER=runpod
# NEXUS_REDIS_URL=redis://your-redis-host:6379

# ═══════════════════════════════════════════════════════════════════
# HUMANIK CLOUD — Security
# Shared secret for HMAC auth between control plane and this instance.
# Injected by control plane. Without this, HMAC middleware rejects
# all non-health requests (server is unreachable without valid HMAC).
# ═══════════════════════════════════════════════════════════════════
# CP_INSTANCE_HMAC_SECRET=your-shared-hmac-secret

# ═══════════════════════════════════════════════════════════════════
# HUMANIK CLOUD — Provider Routing
# Used by heartbeat to tell the ALB how to route requests to this pod.
# RUNPOD_POD_ID is auto-detected from hostname if not set.
# ═══════════════════════════════════════════════════════════════════
# RUNPOD_POD_ID=abc123xyz
# RUNPOD_DC_ID=US-TX-3

# ═══════════════════════════════════════════════════════════════════
# HUMANIK CLOUD — Scaling
# Idle timeout before self-termination. Control plane destroys the
# pod after receiving the termination signal. Set to 0 for persistent
# (never auto-terminate).
# ═══════════════════════════════════════════════════════════════════
IDLE_TIMEOUT_MINUTES=20

# ═══════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════
ENABLE_LOG_REQUESTS=false
DISABLE_LOG_STATS=false

# ═══════════════════════════════════════════════════════════════════
# HUGGINGFACE (only needed for gated/private models)
# ═══════════════════════════════════════════════════════════════════
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
