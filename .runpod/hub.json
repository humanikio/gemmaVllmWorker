{
  "title": "Humanik Gemma 4 MoE Worker",
  "description": "Gemma 4 26B MoE inference (AWQ 4-bit) — OpenAI-compatible API with tool calling, SSE streaming, powered by vLLM 0.19.0. Runs standalone or as a Humanik Cloud managed pool service.",
  "type": "serverless",
  "category": "language",
  "config": {
    "runsOn": "GPU",
    "endpointType": "LB",
    "containerDiskInGb": 20,
    "gpuIds": "ADA_48,-NVIDIA GeForce RTX 4090",
    "gpuCount": 1,
    "allowedCudaVersions": ["12.8", "12.7", "12.6"],
    "presets": [
      {
        "name": "Standard (60K context)",
        "defaults": {
          "MAX_MODEL_LEN": 60000,
          "GPU_MEMORY_UTILIZATION": 0.95,
          "ENABLE_AUTO_TOOL_CHOICE": true,
          "TOOL_CALL_PARSER": "gemma4"
        }
      },
      {
        "name": "Compact (8K context, faster boot)",
        "defaults": {
          "MAX_MODEL_LEN": 8192,
          "GPU_MEMORY_UTILIZATION": 0.95,
          "ENABLE_AUTO_TOOL_CHOICE": true,
          "TOOL_CALL_PARSER": "gemma4"
        }
      }
    ],
    "env": [
      {
        "key": "MAX_MODEL_LEN",
        "input": {
          "name": "Max Context Length",
          "type": "number",
          "description": "Max sequence length (tokens). Higher = more VRAM for KV cache. 60K fits on 48GB GPUs.",
          "default": 60000,
          "min": 1024,
          "max": 128000
        }
      },
      {
        "key": "GPU_MEMORY_UTILIZATION",
        "input": {
          "name": "GPU Memory Utilization",
          "type": "number",
          "description": "Fraction of GPU VRAM to use (0.0-1.0)",
          "default": 0.95,
          "advanced": true
        }
      },
      {
        "key": "ENABLE_AUTO_TOOL_CHOICE",
        "input": {
          "name": "Enable Tool Calling",
          "type": "boolean",
          "description": "Allow tool_choice: auto in requests (OpenAI-compatible tool calling)",
          "default": true,
          "trueValue": "true",
          "falseValue": "false"
        }
      },
      {
        "key": "TOOL_CALL_PARSER",
        "input": {
          "name": "Tool Call Parser",
          "type": "string",
          "description": "Tool call output parser. Must be 'gemma4' for Gemma models (NOT hermes).",
          "default": "gemma4",
          "options": [
            { "label": "Gemma 4 (native)", "value": "gemma4" },
            { "label": "Hermes", "value": "hermes" },
            { "label": "None", "value": "" }
          ]
        }
      },
      {
        "key": "MAX_CONCURRENCY",
        "input": {
          "name": "Max Concurrency",
          "type": "number",
          "description": "Max concurrent requests per worker",
          "default": 30,
          "advanced": true
        }
      },
      {
        "key": "OPENAI_SERVED_MODEL_NAME_OVERRIDE",
        "input": {
          "name": "Served Model Name",
          "type": "string",
          "description": "Model name returned in OpenAI API responses",
          "default": "gemma-4-26b-moe",
          "advanced": true
        }
      },
      {
        "key": "ENABLE_PREFIX_CACHING",
        "input": {
          "name": "Enable Prefix Caching",
          "type": "boolean",
          "description": "Cache common prompt prefixes to speed up repeated requests",
          "default": true,
          "trueValue": "true",
          "falseValue": "false",
          "advanced": true
        }
      },
      {
        "key": "BASE_PATH",
        "input": {
          "name": "Model Storage Path",
          "type": "string",
          "description": "Directory for model weights. Uses /workspace for persistent volumes.",
          "default": "/workspace/models",
          "advanced": true
        }
      }
    ]
  }
}
