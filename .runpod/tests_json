{
  "tests": [
    {
      "name": "basic_prompt_test",
      "input": {
        "prompt": "Explain what a mixture-of-experts model is in two sentences.",
        "sampling_params": {
          "max_tokens": 150,
          "temperature": 0.7
        }
      },
      "timeout": 60000
    },
    {
      "name": "chat_completions_test",
      "input": {
        "openai_route": "/v1/chat/completions",
        "openai_input": {
          "model": "gemma-4-26b-moe",
          "messages": [
            {
              "role": "user",
              "content": "Write a Python function that checks if a string is a palindrome."
            }
          ],
          "max_tokens": 300,
          "temperature": 0.3
        }
      },
      "timeout": 60000
    },
    {
      "name": "streaming_test",
      "input": {
        "openai_route": "/v1/chat/completions",
        "openai_input": {
          "model": "gemma-4-26b-moe",
          "messages": [
            {
              "role": "system",
              "content": "You are a helpful coding assistant."
            },
            {
              "role": "user",
              "content": "What is the difference between a list and a tuple in Python?"
            }
          ],
          "max_tokens": 200,
          "temperature": 0.5,
          "stream": true
        }
      },
      "timeout": 60000
    },
    {
      "name": "models_endpoint_test",
      "input": {
        "openai_route": "/v1/models",
        "openai_input": {}
      },
      "timeout": 10000
    }
  ],
  "config": {
    "gpuTypeId": "NVIDIA L4",
    "gpuCount": 1,
    "env": [
      { "key": "MODEL_NAME", "value": "cyankiwi/gemma-4-26B-A4B-it-AWQ-4bit" },
      { "key": "QUANTIZATION", "value": "awq" },
      { "key": "MAX_MODEL_LEN", "value": "8192" },
      { "key": "GPU_MEMORY_UTILIZATION", "value": "0.95" },
      { "key": "DTYPE", "value": "float16" },
      { "key": "OPENAI_SERVED_MODEL_NAME_OVERRIDE", "value": "gemma-4-26b-moe" },
      { "key": "ENABLE_PREFIX_CACHING", "value": "true" }
    ],
    "allowedCudaVersions": ["12.9", "12.8"]
  }
}
